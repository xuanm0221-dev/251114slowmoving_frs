# Snowflake 연결 정보 (service account + private key / JWT 인증)
# 이 파일을 .env.local로 복사하고 아래 값들을 실제 값으로 채워주세요

SNOWFLAKE_ACCOUNT=your_account_name
SNOWFLAKE_USERNAME=SVC_ORG_FPA
SNOWFLAKE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----
...여러 줄 PEM...
-----END PRIVATE KEY-----"
SNOWFLAKE_WAREHOUSE=your_warehouse
SNOWFLAKE_DATABASE=your_database
SNOWFLAKE_SCHEMA=your_schema
SNOWFLAKE_ROLE=your_role

# 예시:
# SNOWFLAKE_ACCOUNT=abc12345.ap-northeast-2.aws
# SNOWFLAKE_USERNAME=SVC_ORG_FPA
# SNOWFLAKE_WAREHOUSE=COMPUTE_WH
# SNOWFLAKE_DATABASE=FNF
# SNOWFLAKE_SCHEMA=CHN
# SNOWFLAKE_ROLE=ANALYST_ROLE
